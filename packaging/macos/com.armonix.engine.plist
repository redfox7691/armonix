<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  LaunchAgent per il servizio headless di Armonix (senza GUI).
  Installare in ~/Library/LaunchAgents/ e abilitare con:
      launchctl load ~/Library/LaunchAgents/com.armonix.engine.plist
  Oppure tramite: make -f packaging/macos/Makefile.macos install
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.armonix.engine</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/armonix-engine</string>
    </array>

    <!-- Avvia automaticamente al login utente -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Riavvia solo in caso di errore (exit code != 0); uscita pulita = stop -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/armonix-engine.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/armonix-engine.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>
</dict>
</plist>
